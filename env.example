# ─────────────────────────────────────────────
# PulseCore SaaS v8.0 — Environment Variables
# Copy this file to .env for local dev.
# Set each variable in Render Dashboard > Environment.
# NEVER commit your actual .env to GitHub.
# ─────────────────────────────────────────────

# ── REQUIRED ──────────────────────────────────
# Anthropic API key — console.anthropic.com
ANTHROPIC_API_KEY=

# JWT signing secret — any random 64-char string
# Generate: https://generate-secret.vercel.app/64
JWT_SECRET=

# Your Render public URL (set after first deploy)
APP_URL=https://your-app.onrender.com

# ── DATABASE ───────────────────────────────────
# Render sets this automatically when you add a Postgres database.
# For local dev: your local Postgres connection string.
DATABASE_URL=

# ── STRIPE BILLING ─────────────────────────────
# App works in demo mode without these.
# Get keys at: dashboard.stripe.com

# Secret key (sk_live_... or sk_test_...)
STRIPE_SECRET_KEY=

# Webhook signing secret (whsec_...)
STRIPE_WEBHOOK_SECRET=

# Price IDs from Stripe Dashboard > Products > Pricing
STRIPE_PRICE_ID_PRO=
STRIPE_PRICE_ID_AGENCY=

# ── OPTIONAL ───────────────────────────────────
# Email allowed to access /api/metrics
ADMIN_EMAIL=

# Node environment
NODE_ENV=production

# Port (Render sets this automatically)
PORT=3000
